{
  "name": "yadiff",
  "version": "0.1.0",
  "type": "module",
  "description": "Yet another diff viewer — browser UI for local git/jj diffs and public GitHub pull requests.",
  "license": "MIT",
  "author": "baggiiiie",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baggiiiie/yadiff.git"
  },
  "bugs": {
    "url": "https://github.com/baggiiiie/yadiff/issues"
  },
  "homepage": "https://github.com/baggiiiie/yadiff#readme",
  "keywords": ["diff", "git", "jj", "github", "pull-request", "viewer", "cli"],
  "bin": {
    "yadiff": "./bin/yadiff.js"
  },
  "files": [
    "bin/",
    "lib/",
    "src/",
    "index.html",
    "vite.config.ts",
    "tsconfig.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node ./bin/yadiff.js",
    "typecheck": "tsc --noEmit",
    "build": "vite build"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.3",
    "@pierre/trees": "^1.0.0-beta.4",
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "express": "^5.2.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
