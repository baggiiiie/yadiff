{
  "name": "local-diffshub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local browser diff viewer powered by @pierre/diffs and @pierre/trees.",
  "bin": {
    "diffshub-local": "./bin/diffshub-local.js"
  },
  "scripts": {
    "dev": "node ./bin/diffshub-local.js",
    "typecheck": "tsc --noEmit",
    "build": "vite build"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.3",
    "@pierre/trees": "^1.0.0-beta.4",
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.4",
    "typescript": "^5.9.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "express": "^5.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
